{
  "name": "de-slimste-mens",
  "productName": "De Slimste Mens",
  "version": "1.0.0",
  "main": "electron-main.js",
  "description": "De Slimste Mens game",
  "author": "qastrol",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "desktop": "electron .",
    "clean:dist": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true});\"",
    "dist:win": "npm run clean:dist && electron-builder --win nsis",
    "dist:portable": "npm run clean:dist && electron-builder --win portable",
    "dist:linux": "npm run clean:dist && electron-builder --linux AppImage",
    "dist:all": "npm run clean:dist && electron-builder --win portable --linux AppImage"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "express": "^5.1.0",
    "jszip": "^3.10.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "nl.slimstemens.desktop",
    "productName": "De Slimste Mens",
    "executableName": "DeSlimsteMens",
    "asar": true,
    "copyright": "",
    "icon": "assets/slimstemens.ico",
    "artifactName": "DeSlimsteMens.${ext}",
    "files": [
      "*.html",
      "*.css",
      "*.json",
      "server.js",
      "websocket.js",
      "electron-main.js",
      "js/**/*",
      "css/**/*",
      "assets/**/*",
      "galerij/**/*",
      "collectief_geheugen/**/*",
      "SFX/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/slimstemens.ico" 
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/slimstemens.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
